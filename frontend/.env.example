# Copy to .env and fill in once you've deployed the contracts.
# Without VITE_CONTRACT_ID set, the contract panel stays disabled but the
# L1 split-XLM flow still works end-to-end.
VITE_CONTRACT_ID=

# L4 — settlement-token (SEP-41 stablecoin) address. The bill-split contract
# calls token.transfer(payer, creator, share) from inside settle() against
# this address. Optional: leave empty to fall back to "settle just records,
# no funds move".
VITE_STABLE_TOKEN_ID=

# Display label for the settlement token (defaults to "BILL").
VITE_STABLE_SYMBOL=BILL
